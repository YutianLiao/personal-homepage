  "devDependencies": {
    "jsdom": "^29.1.1",
    "markdown-it-mathjax3": "^4.3.2",
    "mermaid": "^11.16.0",
    "turndown": "^7.2.4",
    "vitepress": "^1.6.3",
    "vitepress-plugin-mermaid": "^2.0.17"
  },
  "dependencies": {
    "js-tiktoken": "^1.0.21",
    "katex": "^0.17.0",
    "three": "^0.185.1"
