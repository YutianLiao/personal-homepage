{
  "name": "personal-homepage",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build:learning-modules": "node scripts/build-learning-modules.mjs",
    "sync:knowledge-planet": "node scripts/knowledge-planet.mjs sync",
    "kp:add": "node scripts/knowledge-planet.mjs add-point",
    "kp:remove": "node scripts/knowledge-planet.mjs remove-point",
    "kp:redistribute": "node scripts/knowledge-planet.mjs redistribute",
    "prepare:sudoku": "node scripts/prepare-sudoku-puzzles.mjs",
    "predev": "npm run build:learning-modules && npm run sync:knowledge-planet && npm run prepare:sudoku",
    "prebuild": "npm run build:learning-modules && npm run sync:knowledge-planet && npm run prepare:sudoku",
    "dev": "vitepress dev docs",
